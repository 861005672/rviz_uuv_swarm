Header header

# === 位置 (NED 坐标系) ===
float64 x
float64 y
float64 z

# === 姿态 (欧拉角) ===
float64 phi    # Roll (横滚)
float64 theta  # Pitch (俯仰)
float64 psi    # Yaw (偏航)

# === 线速度 (机体坐标系) ===
float64 u      # Surge (纵荡)
float64 v      # Sway (横荡)
float64 w      # Heave (垂荡)

# === 角速度 (机体坐标系) ===
float64 p      # Roll rate
float64 q      # Pitch rate
float64 r      # Yaw rate

