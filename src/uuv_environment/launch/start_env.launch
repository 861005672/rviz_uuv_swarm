<launch>

    <node pkg="uuv_environment" type="env_spawner.py" name="env_spawner_node" output="screen">
        <rosparam command="load" file="$(find uuv_environment)/env/test.yaml" />
    </node>

    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find uuv_environment)/rviz/rvizconfig.rviz" required="true" />

</launch>