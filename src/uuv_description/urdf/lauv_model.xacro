<?xml version="1.0"?>
<robot name="lauv" xmlns:xacro="http://www.ros.org/wiki/xacro">
  
  <xacro:arg name="namespace" default="uuv_0"/>
  <xacro:property name="ns" value="$(arg namespace)"/>

  <link name="${ns}/base_link">
    <visual>
      <origin xyz="0 0 0" rpy=" ${pi} 0 0"/>
      <geometry>
        <mesh filename="package://uuv_description/meshes/body.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://uuv_description/meshes/body.stl"/>
      </geometry>
    </collision>
  </link>

  <link name="${ns}/thruster_0">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://uuv_description/meshes/propeller.dae"/>
      </geometry>
    </visual>
  </link>

  <joint name="${ns}/thruster_0_joint" type="continuous">
    <parent link="${ns}/base_link"/>
    <child link="${ns}/thruster_0"/>
    <origin xyz="-0.53994 0 0" rpy="0 0 ${pi}"/>
    <axis xyz="1 0 0"/>
  </joint>

  <xacro:macro name="fin_macro" params="id x y z r p yaw mesh_file">
    <link name="${ns}/fin_${id}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://uuv_description/meshes/${mesh_file}"/>
        </geometry>
      </visual>
    </link>
    <joint name="${ns}/fin_${id}_joint" type="revolute">
      <parent link="${ns}/base_link"/>
      <child link="${ns}/fin_${id}"/>
      <origin xyz="${x} ${y} ${z}" rpy="${r} ${p} ${yaw}"/>
      <axis xyz="0 0 1"/>
      <limit lower="-0.785" upper="0.785" effort="10" velocity="10"/>
    </joint>
  </xacro:macro>

  <xacro:fin_macro id="0" x="-0.4" y="0" z="0.04" r="0" p="0" yaw="0" mesh_file="red_fin.dae"/>
  
  <xacro:fin_macro id="1" x="-0.4" y="-0.04" z="0" r="${0.5 * pi}" p="0" yaw="0" mesh_file="black_fin.dae"/>

  <xacro:fin_macro id="2" x="-0.4" y="0" z="-0.04" r="${pi}" p="0" yaw="0" mesh_file="black_fin.dae"/>

  <xacro:fin_macro id="3" x="-0.4" y="0.04" z="0" r="${-0.5 * pi}" p="0" yaw="0" mesh_file="black_fin.dae"/>

</robot>