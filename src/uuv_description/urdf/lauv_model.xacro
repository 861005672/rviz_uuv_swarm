<?xml version="1.0"?>
<robot name="lauv" xmlns:xacro="http://www.ros.org/wiki/xacro">
  
  <xacro:arg name="namespace" default="uuv_0"/>
  <xacro:arg name="dynamics_type" default="fossen" />
  <xacro:arg name="actuator_type" default="lauv" />
  <xacro:arg name="controller_type" default="pid" />
  <xacro:arg name="guidance_type" default="to_goal" />

  <xacro:property name="ns" value="$(arg namespace)"/>

  <xacro:include filename="$(find uuv_description)/urdf/plugins/actuators/lauv_actuator.xacro" />
  <xacro:include filename="$(find uuv_description)/urdf/plugins/dynamics/lauv_fossen_dynamics.xacro" />
  <xacro:include filename="$(find uuv_description)/urdf/plugins/controllers/pid_controller.xacro" />
  <xacro:include filename="$(find uuv_description)/urdf/plugins/sensors/simple_2d_sonar.xacro" />
  <xacro:include filename="$(find uuv_description)/urdf/plugins/guidances/to_goal_guidance.xacro" />


  <xacro:if value="${'$(arg dynamics_type)' == 'fossen'}">
      <xacro:insert_fossen_dynamics update_rate="100.0" publish_debug="true" publish_debug_rate="10.0" />
  </xacro:if>

  <xacro:if value="${'$(arg actuator_type)' == 'lauv'}">
      <xacro:insert_lauv_actuator update_rate="200.0" publish_debug="true" publish_debug_rate="10.0" />
  </xacro:if>  <!-- 将actuator的更新频率设置的很大，相当于就没有了频率控制，就是调用就触发！ -->

  <xacro:if value="${'$(arg controller_type)' == 'pid'}">
      <xacro:insert_pid_controller update_rate="10.0" publish_debug="true" publish_debug_rate="10.0" enable_dyn="false" />
  </xacro:if>

  <xacro:if value="${'$(arg guidance_type)' == 'to_goal'}">
      <xacro:insert_to_goal_guidance update_rate="10.0" publish_debug="true" publish_debug_rate="10.0" cruise_speed="7" acceptance_radius="4.0" max_pitch_deg="40.0" />
  </xacro:if>

  <xacro:insert_simple_2d_sonar name="forward_looking_sonar" update_rate="10.0" beams="30" fov="150.0" max_range="200.0" />



  <link name="${ns}/base_link">
    <visual>
      <origin xyz="0 0 0" rpy=" ${pi} 0 0"/>
      <geometry>
        <mesh filename="package://uuv_description/meshes/body.dae"/>
      </geometry>
    </visual>
    <!-- <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://uuv_description/meshes/body.stl"/>
      </geometry>
    </collision> -->
    <collision>
        <origin xyz="0 0 0" rpy="0 1.570796 0" />
        <geometry>
            <cylinder length="1.1" radius="0.075" /> 
        </geometry>
    </collision>
  </link>

  <link name="${ns}/thruster_0">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://uuv_description/meshes/propeller.dae"/>
      </geometry>
    </visual>
  </link>

  <joint name="${ns}/thruster_0_joint" type="continuous">
    <parent link="${ns}/base_link"/>
    <child link="${ns}/thruster_0"/>
    <origin xyz="-0.53994 0 0" rpy="0 0 ${pi}"/>
    <axis xyz="1 0 0"/>
  </joint>

  <xacro:macro name="fin_macro" params="id x y z r p yaw mesh_file">
    <link name="${ns}/fin_${id}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://uuv_description/meshes/${mesh_file}"/>
        </geometry>
      </visual>
    </link>
    <joint name="${ns}/fin_${id}_joint" type="revolute">
      <parent link="${ns}/base_link"/>
      <child link="${ns}/fin_${id}"/>
      <origin xyz="${x} ${y} ${z}" rpy="${r} ${p} ${yaw}"/>
      <axis xyz="0 0 1"/>
      <limit lower="-0.5237" upper="0.5237" effort="10" velocity="10"/>
    </joint>
  </xacro:macro>

  <xacro:fin_macro id="0" x="-0.4" y="0" z="0.04" r="0" p="0" yaw="0" mesh_file="red_fin.dae"/>
  
  <xacro:fin_macro id="1" x="-0.4" y="-0.04" z="0" r="${0.5 * pi}" p="0" yaw="0" mesh_file="black_fin.dae"/>

  <xacro:fin_macro id="2" x="-0.4" y="0" z="-0.04" r="${pi}" p="0" yaw="0" mesh_file="black_fin.dae"/>

  <xacro:fin_macro id="3" x="-0.4" y="0.04" z="0" r="${-0.5 * pi}" p="0" yaw="0" mesh_file="black_fin.dae"/>

</robot>