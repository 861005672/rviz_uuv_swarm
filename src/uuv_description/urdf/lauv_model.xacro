<?xml version="1.0"?>
<robot name="lauv" xmlns:xacro="http://www.ros.org/wiki/xacro">
  
  <xacro:arg name="namespace" default="uuv_0"/>
  <xacro:arg name="dynamics_type" default="fossen" />
  <xacro:arg name="actuator_type" default="lauv" />
  <xacro:arg name="controller_type" default="pid" />
  <xacro:arg name="guidance_type" default="spacial_flocking" />
  <xacro:arg name="planner_type" default="simple" />
  <xacro:arg name="decision_type" default="vanguard" />

  <xacro:property name="ns" value="$(arg namespace)"/>

  <xacro:include filename="$(find uuv_description)/urdf/plugins/actuators/lauv_actuator.xacro" />
  <xacro:include filename="$(find uuv_description)/urdf/plugins/dynamics/lauv_fossen_dynamics.xacro" />
  <xacro:include filename="$(find uuv_description)/urdf/plugins/controllers/pid_controller.xacro" />
  <xacro:include filename="$(find uuv_description)/urdf/plugins/sensors/simple_2d_sonar.xacro" />
  <xacro:include filename="$(find uuv_description)/urdf/plugins/guidances/to_goal_guidance.xacro" />
  <xacro:include filename="$(find uuv_description)/urdf/plugins/guidances/spacial_flocking_guidance.xacro" />
  <xacro:include filename="$(find uuv_description)/urdf/plugins/planners/simple_planner.xacro" />
  <xacro:include filename="$(find uuv_description)/urdf/plugins/decisions/vanguard_decision.xacro" />
  <xacro:include filename="$(find uuv_description)/urdf/plugins/decisions/cbaa_decision.xacro"/>

  <xacro:if value="${'$(arg dynamics_type)' == 'fossen'}">
      <xacro:insert_fossen_dynamics update_rate="100.0" publish_debug="true" publish_debug_rate="10.0" />
  </xacro:if>

  <xacro:if value="${'$(arg actuator_type)' == 'lauv'}">
      <xacro:insert_lauv_actuator update_rate="200.0" publish_debug="true" publish_debug_rate="10.0" />
  </xacro:if>  <!-- 将actuator的更新频率设置的很大，相当于就没有了频率控制，就是调用就触发！ -->

  <xacro:if value="${'$(arg controller_type)' == 'pid'}">
      <xacro:insert_pid_controller update_rate="10.0" publish_debug="true" publish_debug_rate="10.0" enable_dyn="false" />
  </xacro:if>

  <xacro:if value="${'$(arg guidance_type)' == 'to_goal'}">
      <xacro:insert_to_goal_guidance update_rate="10.0" publish_debug="true" publish_debug_rate="10.0" cruise_speed="7" acceptance_radius="4.0" max_pitch_deg="40.0" />
  </xacro:if>


  <xacro:if value="${'$(arg guidance_type)' == 'spacial_flocking'}">
    <xacro:insert_spacial_flocking_guidance update_rate="10.0" publish_debug="true" publish_debug_rate="10.0" 
        min_speed="1.0" cruise_speed="6.0" max_speed="10.0" max_pitch_deg="30.0" t_ftotal="0.1" forward_tendency="0.0" speed_map_scale="30.0" 
        zeta_p="0.4" zeta_v="10.0" nav_force_limit="30.0"
        zeta_n="0.01" delta_n="120.0" k_pull="1.0" r_comm="150" force_lp_gain="0.2" flock_force_limit="500.0"
        delay_tau="0.0" max_delta_n="400.0" k_delay="0.0" est_window_size="50"
        d_sense="200.0" d_inflation="10.0" zeta_obs="0.01" delta_obs="140.0" num_sectors="10" range_zeta_norm="0.4 1.0" range_zeta_tan="0.4 60.0"
    />
  </xacro:if>


    <!-- delay_tau="0.0" max_delta_n="300.0" k_delay="5.0" est_window_size="50" -->
    <!-- d_sense="180.0" d_inflation="10.0" zeta_obs="0.001" delta_obs="180" num_sectors="10" range_zeta_norm="0.4 2.0" range_zeta_tan="0.4 20.0" -->
    <!--这是好的 内力参数 zeta_n="0.02" delta_n="120.0" k_pull="1.0" r_comm="150" force_lp_gain="0.2" flock_force_limit="2020" -->


  <xacro:if value="${'$(arg planner_type)' == 'simple'}">
    <xacro:insert_simple_planner update_rate="1.0" publish_debug="false" publish_debug_rate="1.0" />
  </xacro:if>

  <xacro:if value="${'$(arg decision_type)' == 'vanguard'}">
      <xacro:insert_vanguard_decision update_rate="1.0" publish_debug="false" publish_debug_rate="1.0" />
  </xacro:if>

  <xacro:if value="${'$(arg decision_type)' == 'cbaa'}">
      <xacro:insert_cbaa_decision update_rate="100.0" publish_debug="false" publish_debug_rate="1.0" 
              max_bundle_size="1" virtual_id_multiplier="100" gossip_size="5" map_range="5000.0" />
  </xacro:if>
  
  <xacro:insert_simple_2d_sonar name="forward_looking_sonar" update_rate="10.0" beams="30" fov="120.0" max_range="200.0" 
  noise_std_base="0.0" noise_vel_factor="0.0" noise_dist_factor="0.0" miss_prob="0.0" false_prob="0.0" sonar_delay="0.0"
  max_patch_error_size="6" max_patch_error_time="6" />

  <!-- noise_std_base="0.0" noise_vel_factor="0.0" noise_dist_factor="0.0" miss_prob="0.0" false_prob="0.0" sonar_delay="0.0" -->
  <!-- noise_std_base="0.35" noise_vel_factor="0.03" noise_dist_factor="0.018" miss_prob="0.1" false_prob="0.04" sonar_delay="0.4"  -->
  <!-- noise_std_base="0.5" noise_vel_factor="0.03" noise_dist_factor="0.03" miss_prob="0.2" false_prob="0.1" sonar_delay="0.4" -->
  <!-- noise_std_base="0.1" noise_vel_factor="0.02" noise_dist_factor="0.01" miss_prob="0.003" false_prob="0.003" sonar_delay="0.4" -->

  <link name="${ns}/base_link">
    <visual>
      <origin xyz="0 0 0" rpy=" ${pi} 0 0"/>
      <geometry>
        <mesh filename="package://uuv_description/meshes/body.dae"/>
      </geometry>
    </visual>
    <!-- <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://uuv_description/meshes/body.stl"/>
      </geometry>
    </collision> -->
    <collision>
        <origin xyz="0 0 0" rpy="0 1.570796 0" />
        <geometry>
            <cylinder length="1.1" radius="0.075" /> 
        </geometry>
    </collision>
  </link>

  <link name="${ns}/thruster_0">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://uuv_description/meshes/propeller.dae"/>
      </geometry>
    </visual>
  </link>

  <joint name="${ns}/thruster_0_joint" type="continuous">
    <parent link="${ns}/base_link"/>
    <child link="${ns}/thruster_0"/>
    <origin xyz="-0.53994 0 0" rpy="0 0 ${pi}"/>
    <axis xyz="1 0 0"/>
  </joint>

  <xacro:macro name="fin_macro" params="id x y z r p yaw mesh_file">
    <link name="${ns}/fin_${id}">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <mesh filename="package://uuv_description/meshes/${mesh_file}"/>
        </geometry>
      </visual>
    </link>
    <joint name="${ns}/fin_${id}_joint" type="revolute">
      <parent link="${ns}/base_link"/>
      <child link="${ns}/fin_${id}"/>
      <origin xyz="${x} ${y} ${z}" rpy="${r} ${p} ${yaw}"/>
      <axis xyz="0 0 1"/>
      <limit lower="-0.5237" upper="0.5237" effort="10" velocity="10"/>
    </joint>
  </xacro:macro>

  <xacro:fin_macro id="0" x="-0.4" y="0" z="0.04" r="0" p="0" yaw="0" mesh_file="red_fin.dae"/>
  
  <xacro:fin_macro id="1" x="-0.4" y="-0.04" z="0" r="${0.5 * pi}" p="0" yaw="0" mesh_file="black_fin.dae"/>

  <xacro:fin_macro id="2" x="-0.4" y="0" z="-0.04" r="${pi}" p="0" yaw="0" mesh_file="black_fin.dae"/>

  <xacro:fin_macro id="3" x="-0.4" y="0.04" z="0" r="${-0.5 * pi}" p="0" yaw="0" mesh_file="black_fin.dae"/>

</robot>