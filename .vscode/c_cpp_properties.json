{
  "configurations": [
    {
      "browse": {
        "databaseFilename": "${default}",
        "limitSymbolsToIncludedHeaders": false
      },
      "includePath": [
        "/opt/ros/noetic/include/**",
        "/usr/include/**",
        "${workspaceFolder}/devel/include/uuv_control/**",
        "${workspaceFolder}/devel/include/uuv_interface/**",
        "${workspaceFolder}/src/uuv_control/include/**",
        "${workspaceFolder}/src/uuv_sensor/include/**",
        "${workspaceFolder}/src/uuv_interface/include/**"
      ],
      "name": "ROS",
      "intelliSenseMode": "gcc-x64",
      "compilerPath": "/usr/bin/gcc",
      "cStandard": "gnu11",
      "cppStandard": "c++14"
    }
  ],
  "version": 4
}